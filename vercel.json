{
  "github": {
    "silent": true
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/privacy(|.html)", "destination": "/privacy.html" },
    { "source": "/privacy-policy", "destination": "/privacy.html" },
    { "source": "/terms(|.html)", "destination": "/terms.html" },
    { "source": "/terms-of-service", "destination": "/terms.html" },
    { "source": "/((?!assets/|privacy|terms|favicon\\.ico|manifest\\.json|pwa-).*|$)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
