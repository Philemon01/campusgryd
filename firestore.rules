rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net (Default Deny Catch-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES AND HELPERS ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- COLLECTION RULES ---

    // 1. Timetables Collection (Under RSU Security Schema)
    match /timetables/{timetableId} {
      
      // Checks if the incoming data matches the client-side app standard model
      function isValidAppTimetable(data) {
        return data.creatorId == request.auth.uid
          && data.creatorEmail is string
          && data.faculty is string
          && data.department is string
          && data.level is string
          && data.semester is string
          && data.status is string
          && data.createdAt is string;
      }

      // Standalone schema-based validation helper (The Pillar of Hardened Rules)
      function isValidBlueprintTimetable(data) {
        return data.timetableId is string && data.timetableId.size() <= 128
          && data.ownerId == request.auth.uid
          && data.ownerEmail is string && data.ownerEmail.size() <= 128
          && data.imageUrl is string && data.imageUrl.size() <= 1024
          && data.isPublished is bool
          && data.createdAt is timestamp
          && data.updatedAt is timestamp
          && data.extractedData is map
          && data.extractedData.title is string && data.extractedData.title.size() <= 256
          && data.extractedData.schedule is list
          && data.keys().hasAll([
            'timetableId', 'ownerId', 'ownerEmail', 'imageUrl', 
            'isPublished', 'createdAt', 'updatedAt', 'extractedData'
          ]) && data.keys().size() == 8;
      }

      // Check validation inside slots in schedule array
      function isValidScheduleItem(item) {
        return item is map 
          && item.day is string && item.day.size() <= 32
          && item.time is string && item.time.size() <= 64
          && item.course is string && item.course.size() <= 128
          && item.venue is string && item.venue.size() <= 256;
      }

      // Read rules: Any authenticated user can read all timetables
      allow get, list: if isSignedIn();

      // Write rules: Only authenticated owner can perform mutate operations (either standard app model or blueprint)
      allow create: if isSignedIn() && (
        (isOwner(incoming().creatorId) && isValidAppTimetable(incoming())) ||
        (isOwner(incoming().ownerId) && isValidBlueprintTimetable(incoming()) && incoming().createdAt == request.time && incoming().updatedAt == request.time)
      );

      allow update: if isSignedIn() && (
        (isOwner(existing().creatorId) && isOwner(incoming().creatorId) && isValidAppTimetable(incoming())) ||
        (get(/databases/$(database)/documents/timetables/$(timetableId)).data.keys().hasAny(['ownerId']) && isOwner(existing().ownerId) && isOwner(incoming().ownerId) && isValidBlueprintTimetable(incoming()) && incoming().createdAt == existing().createdAt && incoming().updatedAt == request.time)
      );

      allow delete: if isSignedIn() && (
        (existing().keys().hasAny(['creatorId']) && isOwner(existing().creatorId)) ||
        (existing().keys().hasAny(['ownerId']) && isOwner(existing().ownerId))
      );

      // Support slots sub-collection for legacy relational sync components (Optional fallback)
      match /slots/{slotId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && (
          (get(/databases/$(database)/documents/timetables/$(timetableId)).data.keys().hasAny(['ownerId']) && get(/databases/$(database)/documents/timetables/$(timetableId)).data.ownerId == request.auth.uid) ||
          (get(/databases/$(database)/documents/timetables/$(timetableId)).data.keys().hasAny(['creatorId']) && get(/databases/$(database)/documents/timetables/$(timetableId)).data.creatorId == request.auth.uid)
        );
        allow delete: if isSignedIn() && (
          (get(/databases/$(database)/documents/timetables/$(timetableId)).data.keys().hasAny(['ownerId']) && get(/databases/$(database)/documents/timetables/$(timetableId)).data.ownerId == request.auth.uid) ||
          (get(/databases/$(database)/documents/timetables/$(timetableId)).data.keys().hasAny(['creatorId']) && get(/databases/$(database)/documents/timetables/$(timetableId)).data.creatorId == request.auth.uid)
        );
      }
    }

    // 2. User Profiles Collection
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow create, update: if isSignedIn() && isOwner(userId);
    }

    // 3. User Sync Tracks
    match /user_syncs/{syncId} {
      allow read, write: if isSignedIn();
    }

    // 4. Notifications Records
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    // 5. User Contributed Locations
    match /user_locations/{locationId} {
      function isValidUserLocation(data) {
        return data.id is string && data.id.size() <= 128
          && data.ownerId == request.auth.uid
          && data.officialName is string && data.officialName.size() <= 256
          && data.aliases is list && data.aliases.size() <= 20
          && data.type is string && data.type.size() <= 64
          && data.description is string && data.description.size() <= 1024
          && data.landmark is string && data.landmark.size() <= 256
          && data.coordinates is list && data.coordinates.size() == 2
          && data.coordinates[0] is number
          && data.coordinates[1] is number
          && data.createdAt is string && data.createdAt.size() <= 64;
      }

      allow get, list: if true;
      allow create: if isSignedIn() && isValidId(locationId) && isValidUserLocation(incoming());
      allow update: if isSignedIn() && isValidId(locationId) && isOwner(existing().ownerId)
        && incoming().ownerId == existing().ownerId && isValidUserLocation(incoming());
      allow delete: if isSignedIn() && isValidId(locationId) && isOwner(existing().ownerId);
    }
  }
}
